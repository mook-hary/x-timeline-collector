# Environment (keep .env.example tracked)
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Playwright / browser profile (cookies, sessions, login data)
browser-data/

# Private knowledge store
knowledge-base/

# Disposable local pipeline intermediates (keep Reader publish set trackable)
output/*
!output/digest-reader/
!output/digest-reader/**
# Local screenshots / extras under Reader dir stay private by default
output/digest-reader/*.png
output/digest-reader/*.jpg
output/digest-reader/*.jpeg
output/digest-reader/*.webp

# Local Morning API usage history
data/

# Run workspaces (including retest / experiment dirs)
runs/
runs-*/

# Generated pipeline working files
.pipeline-work/

# Local logs
logs/

# OS / editor / cache
.DS_Store
*.log
*.swp
*.swo
.idea/
.vscode/
*.tmp
*.temp
.cache/
